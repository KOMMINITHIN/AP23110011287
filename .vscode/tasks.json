{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "start-dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--port",
				"3001"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "start-dev-3001",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"-p",
				"3001"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "start-dev-port-3001",
			"type": "shell",
			"command": "$env:PORT='3001'; npm run dev",
			"isBackground": true,
			"group": "build"
		}
	]
}